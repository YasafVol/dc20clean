{
	"name": "dc20clean",
	"version": "0.10.5",
	"scripts": {
		"dev": "vite dev",
		"convex:dev": "convex dev",
		"seed": "npx convex run seed:seedAllOfficialData",
		"seed:monsters": "npx convex run seed:seedOfficialMonsters",
		"seed:features": "npx convex run seed:seedOfficialFeatures",
		"build": "vite build",
		"preview": "vite preview",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"e2e:desktop": "E2E_FIXTURE=./test-character-gibble.json npx playwright test --project=desktop --workers=1",
		"e2e:mobile": "E2E_FIXTURE=./test-character-gibble.json npx playwright test --project=mobile --workers=1",
		"e2e:all": "E2E_FIXTURE=./test-character-gibble.json npx playwright test --workers=1",
		"e2e:parallel:desktop": "E2E_FIXTURE=./test-character-gibble.json E2E_WORKERS=${E2E_WORKERS:-4} npx playwright test --project=desktop --workers=${E2E_WORKERS:-4}",
		"e2e:parallel:mobile": "E2E_FIXTURE=./test-character-gibble.json E2E_WORKERS=${E2E_WORKERS:-4} npx playwright test --project=mobile --workers=${E2E_WORKERS:-4}",
		"e2e:parallel:all": "E2E_FIXTURE=./test-character-gibble.json E2E_WORKERS=${E2E_WORKERS:-4} npx playwright test --workers=${E2E_WORKERS:-4}",
		"e2e:parallel:auto": "E2E_FIXTURE=./test-character-gibble.json E2E_WORKERS=$(node -e \"console.log(Math.max(1, Math.floor(require('os').cpus().length/2)))\") npx playwright test --workers=$E2E_WORKERS",
		"e2e:agentic:smoke": "playwright test --project=desktop e2e/agentic/agentic-character-creation.e2e.spec.ts",
		"e2e:agentic": "playwright test --project=desktop e2e/agentic",
		"e2e:agentic:generate": "vite-node scripts/e2e/generateCharacterRecipes.ts",
		"e2e:agentic:summarize": "vite-node scripts/e2e/summarizeAgenticRuns.ts",
		"export:list-fields": "node scripts/listPdfFields.mjs | tee docs/systems/pdf-form-fields-v0.9.5.json",
		"pdf:fields:audit": "node scripts/pdf/auditPdfFields.mjs",
		"pdf:fields:audit:current": "node scripts/pdf/auditPdfFields.mjs --old \"src/lib/pdf/095/DC20_Beta_0_9_5_(fillable)_Character_Sheet.pdf\" --new \"src/lib/pdf/010/DC20 Beta 0.10 (fillable) Character Sheet.pdf\" --old-label 0.9.5 --new-label 0.10 --field-map src/lib/pdf/fieldMap.dc20-0.10.ts --out docs/migration/pdf-field-audit-current.json",
		"export:local": "node scripts/localExportPOC.mjs",
		"spells:extract:0105": "node scripts/spells/dc20-0105-spells.mjs",
		"spells:validate:0105": "node scripts/spells/dc20-0105-spells.mjs --check",
		"spells:generate:0105": "node scripts/spells/dc20-0105-spells.mjs --write",
		"martials:extract:0105": "node scripts/martials/dc20-0105-maneuvers.mjs",
		"martials:validate:0105": "node scripts/martials/dc20-0105-maneuvers.mjs --check",
		"martials:generate:0105": "node scripts/martials/dc20-0105-maneuvers.mjs --write",
		"ancestries:extract:0105": "node scripts/ancestries/dc20-0105-ancestries.mjs",
		"ancestries:validate:0105": "node scripts/ancestries/dc20-0105-ancestries.mjs --check",
		"ancestries:generate:0105": "node scripts/ancestries/dc20-0105-ancestries.mjs --write",
		"background:extract:0105": "node scripts/background/dc20-0105-background.mjs",
		"background:validate:0105": "node scripts/background/dc20-0105-background.mjs --check",
		"background:generate:0105": "node scripts/background/dc20-0105-background.mjs --write",
		"background:names:validate:0105": "vite-node scripts/background/dc20-0105-background-names.ts",
		"background:traits:extract:0105": "vite-node scripts/background/dc20-0105-background-trait-effects.ts",
		"background:traits:validate:0105": "vite-node scripts/background/dc20-0105-background-trait-effects.ts --check",
		"background:traits:generate:0105": "vite-node scripts/background/dc20-0105-background-trait-effects.ts --write",
		"conditions:extract:0105": "node scripts/conditions/dc20-0105-conditions.mjs",
		"conditions:validate:0105": "node scripts/conditions/dc20-0105-conditions.mjs --check",
		"conditions:generate:0105": "node scripts/conditions/dc20-0105-conditions.mjs --write",
		"classes:extract:0105": "node scripts/classes/dc20-0105-classes.mjs",
		"classes:validate:0105": "node scripts/classes/dc20-0105-classes.mjs --check",
		"classes:generate:0105": "node scripts/classes/dc20-0105-classes.mjs --write",
		"classes:effects:extract": "vite-node scripts/classes/dc20-0105-class-effects.ts",
		"classes:effects:validate": "vite-node scripts/classes/dc20-0105-class-effects.ts --check",
		"classes:effects:generate": "vite-node scripts/classes/dc20-0105-class-effects.ts --write",
		"classes:audit:extract": "node scripts/classes/dc20-0105-class-audit-report.mjs",
		"classes:audit:validate": "node scripts/classes/dc20-0105-class-audit-report.mjs --check",
		"classes:audit:generate": "node scripts/classes/dc20-0105-class-audit-report.mjs --write",
		"leveling:review:extract:0105": "vite-node scripts/leveling/dc20-0105-leveling-review.ts",
		"leveling:review:validate:0105": "vite-node scripts/leveling/dc20-0105-leveling-review.ts --check",
		"leveling:review:generate:0105": "vite-node scripts/leveling/dc20-0105-leveling-review.ts --write"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@playwright/test": "^1.49.1",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.1.13",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.16.5",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@types/react-router-dom": "^5.3.3",
		"@types/styled-components": "^5.1.34",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/browser": "^3.2.3",
		"babel-plugin-styled-components": "^2.1.4",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"globals": "^16.0.0",
		"playwright": "^1.53.0",
		"prettier": "^3.4.2",
		"publint": "^0.3.2",
		"shadcn": "^3.6.3",
		"tailwindcss": "^4.0.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.6",
		"vite-plugin-devtools-json": "^0.2.0"
	},
	"keywords": [
		"react"
	],
	"dependencies": {
		"@convex-dev/auth": "^0.0.90",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@node-rs/argon2": "^2.0.2",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.1.0",
		"@sentry/react": "^8.0.0",
		"@vercel/analytics": "^1.4.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"convex": "^1.31.5",
		"fantasy-name-generator": "^2.0.0",
		"framer-motion": "^12.33.0",
		"i18next": "^25.8.4",
		"i18next-browser-languagedetector": "^8.2.0",
		"lucide-react": "^0.469.0",
		"pdf-lib": "^1.17.1",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-i18next": "^16.5.4",
		"react-router-dom": "^7.8.1",
		"repomix": "^1.4.2",
		"styled-components": "^6.1.19",
		"tailwind-merge": "^2.6.0",
		"zod": "^4.0.5"
	}
}
